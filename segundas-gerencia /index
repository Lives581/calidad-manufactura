/* ============ RENDER PERÍODO ============ */
function periodLabel(mode,values,Y){
  const v=values.slice().sort((a,b)=>a-b);
  if(mode==="month"){
    return v.length===1?(MESES[v[0]]+" "+Y):(v.map(m=>MESES[m]).join(", ")+" "+Y);
  }
  if(v.length===1)return "Sem "+v[0];
  const consec=v.every((x,i)=>i===0||x===v[i-1]+1);
  return consec?("Sem "+v[0]+"–"+v[v.length-1]):("Sem "+v.join(", "));
}
