function lfsSeries(rows,kind,valf){const by={};rows.forEach(r=>{const k=kind==="week"?r.sem:monthOfRow(r);if(k==null||(kind==="week"&&!(k>0)))return;by[k]=(by[k]||0)+(valf?valf(r):r.cant);});return by;}
function lfsTrend(by,kind,selK){const ks=Object.keys(by).map(Number).sort((a,b)=>a-b);let cur,prev;if(selK!=null){cur=selK;prev=ks.filter(k=>k<selK).pop();}else{cur=ks[ks.length-1];prev=ks[ks.length-2];}if(cur==null||prev==null||by[cur]==null||by[prev]==null)return null;return by[cur]-by[prev];}
function lfsBadgeInv(t){if(t==null)return '<span class="tfl">\u2192 s/d</span>';return t>0?'<span class="tdn">\u25B2 +'+nf(t)+'</span>':t<0?'<span class="tup">\u25BC '+nf(t)+'</span>':'<span class="tfl">\u2192 estable</span>';}
function lfsEvo(by,kind,selK,unit){let keys;if(kind==="week"){keys=Object.keys(by).map(Number).sort((a,b)=>a-b).slice(-10);}else{keys=[0,1,2,3,4,5];}return keys.map(k=>{const v=by[k];const lbl=kind==="week"?("S"+k):MESES[k];const sel=(selK!=null&&k===selK)?' style="outline:2px solid #333;outline-offset:-2px"':'';if(!v)return '<div class="m nd"'+sel+'><div class="mn">'+lbl+'</div><div class="mp">\u2014</div><div class="mt">0</div></div>';return '<div class="m"'+sel+'><div class="mn">'+lbl+'</div><div class="mp">'+nf(v)+'</div><div class="mt">'+unit+'</div></div>';}).join("");}
