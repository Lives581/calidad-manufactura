    ins.push('El nivel de segundas '+(dd>0.05?'<b>empeor\u00F3</b>':(dd<-0.05?'<b>mejor\u00F3</b>':'se mantuvo'))+' en '+latest+' ('+(pP!=null?pP+'% \u2192 ':'')+pL+'%)'+(pL>META?', por encima de la meta de 2.50%':'')+'.');
    ins.push('El valor FOB de las segundas en '+latest+(partial(latest)?' (a la fecha)':'')+' fue de <b>'+fmtM(moneyYear(latest))+'</b>; en '+ys.length+' a\u00F1os suman <b>'+fmtM(totM)+'</b>.');
    if(area2.length>=2)ins.push('<b>'+area2[0].k+'</b> y <b>'+area2[1].k+'</b> concentran el <b>'+area2sum.toFixed(0)+'%</b> de las segundas de '+latest+'.');
    if(KIND==="gerencia"&&cliT&&cliT[0])ins.push('<b>'+cliT[0].k+'</b> concentra el <b>'+cliT[0].p+'%</b>: cualquier mejora ah\u00ED mueve el total de la empresa.');

    host.innerHTML='<div class="elead"><div class="eltx">'+ins[0]+' En '+ys.length+' a\u00F1os, el valor FOB de las segundas suma <b>'+fmtM(totM)+'</b>.</div></div>'
      +'<div class="esec"><div class="est">\u00BFVamos mejor o peor? \u2014 % de segundas por a\u00F1o</div><div class="echips">'+chips+'</div><div class="ecard"><div class="ecw"><canvas id="cePct"></canvas></div></div></div>'
      +'<div class="esec"><div class="est">\u00BFCu\u00E1nto vale? \u2014 valor FOB de las segundas (US$)</div><div class="emoney">'+mcards+'</div><div class="ecard"><div class="ecw"><canvas id="ceMoney"></canvas></div></div></div>'
      +'<div class="esec"><div class="est">\u00BFD\u00F3nde y en qu\u00E9 se concentra?</div><div class="egrid">'+concBlocks+'</div></div>'
      +'<div class="esec"><div class="est">En resumen</div><ul class="eins">'+ins.map(function(t){return '<li>'+t+'</li>';}).join("")+'</ul></div>';

    var SAGE="#10B981",TAUPE="#B45309",ROSE="#DC2626",RED="#DC2626",WARML="#F1F6F4";
    var pcts=ys.map(pctYear);
    reg(new Chart(document.getElementById("cePct"),{type:"line",data:{labels:ys,datasets:[{label:"% de segundas",data:pcts,borderColor:SAGE,backgroundColor:"rgba(105,137,98,.08)",borderWidth:3,pointRadius:5,pointBackgroundColor:ys.map(function(y){return pctYear(y)>META?RED:SAGE;}),fill:true,tension:.25},{label:"Meta 2.50%",data:ys.map(function(){return META;}),borderColor:ROSE,borderWidth:1.5,borderDash:[6,4],pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:"top",labels:{boxWidth:14,usePointStyle:true}},tooltip:{callbacks:{label:function(c){return c.dataset.label+": "+c.raw+"%";}}}},scales:{x:{grid:{display:false}},y:{min:0,suggestedMax:4.5,grid:{color:WARML},ticks:{callback:function(v){return v+"%";}}}}}}));
    reg(new Chart(document.getElementById("ceMoney"),{type:"bar",data:{labels:ys,datasets:[{data:moneys,backgroundColor:ys.map(function(y){return partial(y)?"#F59E0B":(pctYear(y)>META?RED:TAUPE);}),borderRadius:5}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return "$"+Math.round(c.raw).toLocaleString();}}}},scales:{x:{grid:{display:false}},y:{grid:{color:WARML},ticks:{callback:function(v){return "$"+(v/1000)+"K";}}}}}}));
    var hoy=new Date().toLocaleDateString("es-PE",{day:"numeric",month:"long",year:"numeric"});
    var ft=document.getElementById("foot");if(ft)ft.innerHTML="Confidencial \u2014 Uso Interno \u00B7 Calidad Manufactura LIVES \u00B7 "+(KIND==="gerencia"?"Gerencia":"Interno")+" \u00B7 Comparativo ejecutivo \u00B7 * a\u00F1o en curso parcial \u00B7 Generado el "+hoy;
  }
  if(typeof window.renderCompare==="function"){var _rc=window.renderCompare;window.renderCompare=function(){try{buildExecCompare();}catch(e){console.error("execcmp",e);try{return _rc.apply(this,arguments);}catch(e2){}}};}

  /* ===== Vista de resumen anual (botones 2022-2024) ===== */
  function dimBars(dim){var s=share(dim);var ks=Object.keys(s).sort(function(a,b){return s[b]-s[a];}).slice(0,8);return {labels:ks,data:ks.map(function(k){return +s[k].toFixed(1);})};}
  function topk(dim){var s=share(dim);var k=Object.keys(s).sort(function(a,b){return s[b]-s[a];})[0];return k?(k+" ("+s[k].toFixed(0)+"%)"):"\u2014";}
  function ensureAnnualView(){if(document.getElementById("annualView"))return;var mv=document.getElementById("mainView");if(!mv||!mv.parentNode)return;var av=document.createElement("div");av.id="annualView";av.style.display="none";mv.parentNode.insertBefore(av,mv.nextSibling);}
  function annualButtons(){var yb=document.getElementById("yearBtns");if(!yb)return false;if(yb.querySelector(".aybtn"))return true;if(!window.__SEG_ANNUAL__)return false;var ys=Object.keys(window.__SEG_ANNUAL__).sort();var html=ys.map(function(y){return '<button class="mbtn ybtn aybtn" data-y="'+y+'" type="button" title="Resumen anual hist\u00F3rico" onclick="showAnnual(\''+y+'\')">'+y+'</button>';}).join("");yb.insertAdjacentHTML("afterbegin",html);return true;}
  function renderAnnual(y){
    var a=window.__SEG_ANNUAL__[y];if(!a)return;var av=document.getElementById("annualView");
    av.innerHTML='<div class="note"><b>\uD83D\uDCC5 Resumen anual '+y+' (hist\u00F3rico)</b> \u2014 reporte anual, sin detalle semanal/mensual ni telas. % = segundas/confeccionadas (prendas reales). Los desgloses son % de participaci\u00F3n.</div>'
      +'<div class="kpis"><div class="kpi"><div class="v" style="color:'+(a.pct>2.5?"#DC2626":"var(--sage)")+'">'+a.pct+'%</div><div class="l">% de segundas</div><div class="s">Meta 2.50%</div></div><div class="kpi"><div class="v">'+nf(a.seg)+'</div><div class="l">Segundas</div></div><div class="kpi"><div class="v">'+nf(a.conf)+'</div><div class="l">Confeccionadas</div></div><div class="kpi"><div class="v">'+fmtM(a.precio||0)+'</div><div class="l">Valor FOB segundas</div></div><div class="kpi"><div class="v">'+nf(a.desp)+'</div><div class="l">Despachadas</div></div></div>'
      +'<div class="focos"><div class="fk-hd">\uD83D\uDD0E Aspectos del a\u00F1o '+y+' <span>lo m\u00E1s recurrente del a\u00F1o</span></div><div class="fk-grid"><div class="fk-tile"><div class="fk-t">\u00C1rea m\u00E1s cr\u00EDtica</div><div class="fk-big" style="font-size:19px">'+topk(a.area)+'</div></div><div class="fk-tile"><div class="fk-t">Motivo m\u00E1s recurrente</div><div class="fk-big" style="font-size:19px">'+topk(a.motivo)+'</div></div><div class="fk-tile"><div class="fk-t">Cliente top</div><div class="fk-big" style="font-size:19px">'+topk(a.cliente)+'</div></div><div class="fk-tile"><div class="fk-t">Grupo top</div><div class="fk-big" style="font-size:19px">'+topk(a.grupo)+'</div></div><div class="fk-tile"><div class="fk-t">Estilo top</div><div class="fk-big" style="font-size:19px">'+topk(a.estilo)+'</div></div></div></div>'
      +'<div class="grid2"><div class="panel"><div class="pt">\uD83D\uDCE6 Grupos m\u00E1s recurrentes</div><div class="ph">% de participaci\u00F3n en las segundas del a\u00F1o.</div><div class="cwrap" style="height:300px;"><canvas id="avGrupo"></canvas></div></div><div class="panel"><div class="pt">\uD83C\uDFF7\uFE0F Estilos m\u00E1s recurrentes</div><div class="ph">% de participaci\u00F3n.</div><div class="cwrap" style="height:300px;"><canvas id="avEstilo"></canvas></div></div><div class="panel"><div class="pt">\u2699\uFE0F \u00C1reas generadoras</div><div class="ph">% de participaci\u00F3n.</div><div class="cwrap" style="height:300px;"><canvas id="avArea"></canvas></div></div><div class="panel"><div class="pt">\uD83D\uDD27 Motivos</div><div class="ph">% de participaci\u00F3n.</div><div class="cwrap" style="height:300px;"><canvas id="avMot"></canvas></div></div><div class="panel"><div class="pt">\uD83D\uDC65 Clientes</div><div class="ph">% de participaci\u00F3n.</div><div class="cwrap" style="height:300px;"><canvas id="avCli"></canvas></div></div></div>';
    var mk=function(id,dim,color){var b=dimBars(dim);reg(new Chart(document.getElementById(id),{type:"bar",data:{labels:b.labels,datasets:[{data:b.data,backgroundColor:color,borderRadius:3,barThickness:16}]},options:{indexAxis:"y",responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{callbacks:{label:function(c){return c.raw+"%";}}}},scales:{x:{min:0,grid:{color:"#F1F6F4"},border:{display:false},ticks:{callback:function(v){return v+"%";}}},y:{grid:{display:false},border:{color:"#DCE5E2"},ticks:{font:{size:9}}}}}}));};
    mk("avGrupo",a.grupo,"#B45309");mk("avEstilo",a.estilo,"#4E6B78");mk("avArea",a.area,"#10B981");mk("avMot",a.motivo,"#DC2626");mk("avCli",a.cliente,"#F59E0B");
  }
  window.showAnnual=function(y){var a=window.__SEG_ANNUAL__&&window.__SEG_ANNUAL__[y];if(!a)return;document.getElementById("mainView").style.display="none";document.getElementById("compareView").style.display="none";ensureAnnualView();document.getElementById("annualView").style.display="block";["modeWrap","weekWrap","monthWrap"].forEach(function(id){var e=document.getElementById(id);if(e)e.style.display="none";});document.querySelectorAll(".ybtn").forEach(function(b){b.classList.toggle("active",b.getAttribute("data-y")===String(y));});if(typeof clearCharts==="function")clearCharts();renderAnnual(y);window.scrollTo(0,0);};
  function hideAnnual(){var av=document.getElementById("annualView");if(av)av.style.display="none";document.querySelectorAll(".aybtn").forEach(function(b){b.classList.remove("active");});}
  if(typeof window.selectYear==="function"){var _sy=window.selectYear;window.selectYear=function(){hideAnnual();var r=_sy.apply(this,arguments);try{ensureAnnualView();annualButtons();}catch(e){}return r;};}
  if(typeof window.showCompare==="function"){var _sc=window.showCompare;window.showCompare=function(){hideAnnual();return _sc.apply(this,arguments);};}
  var iv=setInterval(function(){if(typeof STATE!=="undefined"&&STATE&&document.getElementById("yearBtns")&&document.querySelectorAll("#yearBtns .ybtn:not(.aybtn)").length){try{ensureAnnualView();annualButtons();}catch(e){}clearInterval(iv);}},600);
})();

</script>


