<script>
const KIND="gerencia";
const SAGE="#10B981",SLATE="#4E6B78",TAUPE="#B45309",ROSE="#DC2626",TAN="#F59E0B",WARM="#DCE5E2",WARML="#F1F6F4",STONE="#5F726C";
Chart.defaults.font.family="Calibri, Arial, sans-serif";Chart.defaults.font.size=12;Chart.defaults.color=STONE;Chart.defaults.borderColor=WARML;
Chart.defaults.plugins.tooltip.backgroundColor="rgba(51,51,51,0.95)";Chart.defaults.plugins.tooltip.padding=10;Chart.defaults.plugins.tooltip.cornerRadius=4;
const nf=n=>Number(n).toLocaleString("es-PE");
const MESES=["Ene","Feb","Mar","Abr","May","Jun","Jul","Ago","Sep","Oct","Nov","Dic"];
const META=2.5;
const FIX={1:0,2:0,3:0,4:0,5:1,6:1,7:1,8:1,9:1,10:2,11:2,12:2,13:2,14:3,15:3,16:3,17:3,18:4,19:4,20:4,21:4,22:5,23:5,24:5,25:5};
let charts=[];const reg=c=>{charts.push(c);return c;};function clearCharts(){charts.forEach(c=>c.destroy());charts=[];}
let STATE=null,CURMODE="week",CURVAL=null,CURYEAR=null,CURVIEW="year",CURF={kind:null,key:null};
let SELWEEKS=[],SELMONTHS=[]; // selección múltiple de semanas/meses (arrays; 1 elemento = selección simple)
function curTok(){if(CURMODE==="year")return "acum";var v=Array.isArray(CURVAL)?CURVAL[CURVAL.length-1]:CURVAL;return CURMODE==="week"?("w:"+v):("m:"+v);}

const valueLabel={id:"valueLabel",afterDatasetsDraw(chart,a,opts){const{ctx}=chart;ctx.save();const meta=chart.getDatasetMeta(0);meta.data.forEach((bar,i)=>{const raw=chart.data.datasets[0].data[i];const ex=opts.extra?opts.extra[i]:"";const sf=opts.suffix||"";ctx.fillStyle="#333";ctx.font="700 11px Calibri, Arial";ctx.textBaseline="middle";if(chart.options.indexAxis==="y"){ctx.textAlign="left";ctx.fillText(raw+sf+(ex||""),bar.x+6,bar.y);}else{ctx.textAlign="center";ctx.fillText(raw+sf,bar.x,bar.y-8);}});ctx.restore();}};

/* setup título según KIND */
document.getElementById("hTitle").textContent=KIND==="gerencia"?"REPORTE DE SEGUNDAS EN PRENDAS CONFECCIONADAS":"REPORTE DE SEGUNDAS EN PRENDAS CONFECCIONADAS - INTERNO";
document.getElementById("hSub").textContent=KIND==="gerencia"?"Segundas sobre prendas confeccionadas · 2026 vs 2025":"Detalle por cliente, motivo, grupo, estilo y tela";
document.title=KIND==="gerencia"?"Segundas — Gerencia · LIVES":"Segundas — Interno · LIVES";
function applyKind(){document.querySelectorAll("[data-kind]").forEach(el=>{const k=el.getAttribute("data-kind");el.classList.toggle("khide",!(k===KIND||k==="both"));});}

/* carga */
const drop=document.getElementById("drop"),fileInput=document.getElementById("file");
fileInput.addEventListener("change",e=>{if(e.target.files[0])handleFile(e.target.files[0]);});
["dragenter","dragover"].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.add("over");}));
["dragleave","drop"].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.remove("over");}));
drop.addEventListener("drop",e=>{if(e.dataTransfer.files[0])handleFile(e.dataTransfer.files[0]);});
drop.addEventListener("click",e=>{if(e.target.tagName!=="BUTTON")fileInput.click();});
// (listeners viejos de <select> reemplazados por toggleWeek/toggleMonth en los pills)
function showErr(m){const el=document.getElementById("err");el.style.display="block";el.innerHTML="⚠ "+m;}

function buildWeekPills(wl){
  const panel=document.getElementById("weekMsPanel");
  panel.innerHTML=wl.map(w=>`<label class="msopt"><input type="checkbox" data-w="${w}" onchange="toggleWeek(${w})"> Semana ${w}</label>`).join("");
}
function weekBtnLabel(){
  if(!SELWEEKS.length)return "—";
  if(SELWEEKS.length===1)return "Semana "+SELWEEKS[0];
  const v=SELWEEKS.slice().sort((a,b)=>a-b);
  const consec=v.every((x,i)=>i===0||x===v[i-1]+1);
  return consec?("Sem "+v[0]+"–"+v[v.length-1]):(v.length+" semanas");
}
function toggleWeekDrop(){const p=document.getElementById("weekMsPanel");p.classList.toggle("open");}
document.addEventListener("click",function(e){
  const d=document.getElementById("weekMsDrop");
  if(d&&!d.contains(e.target))document.getElementById("weekMsPanel").classList.remove("open");
});
function buildMonthPills(ml,y){const box=document.getElementById("monthPills");box.innerHTML=ml.map(m=>`<button type="button" class="pbtn" data-m="${m}" title="${MESES[m]} ${y}" onclick="toggleMonth(${m})">${MESES[m]}</button>`).join("");}
function syncWeekPillsUI(){
  document.querySelectorAll("#weekMsPanel input[type=checkbox]").forEach(c=>c.checked=SELWEEKS.includes(+c.getAttribute("data-w")));
  const btn=document.getElementById("weekMsBtn");if(btn)btn.textContent=weekBtnLabel();
}
function syncMonthPillsUI(){document.querySelectorAll("#monthPills .pbtn").forEach(b=>b.classList.toggle("active",SELMONTHS.includes(+b.getAttribute("data-m"))));}
function toggleWeek(w){const i=SELWEEKS.indexOf(w);if(i>=0){if(SELWEEKS.length>1)SELWEEKS.splice(i,1);}else SELWEEKS.push(w);syncWeekPillsUI();renderPeriod("week",SELWEEKS.slice());}
function toggleMonth(m){const i=SELMONTHS.indexOf(m);if(i>=0){if(SELMONTHS.length>1)SELMONTHS.splice(i,1);}else SELMONTHS.push(m);syncMonthPillsUI();renderPeriod("month",SELMONTHS.slice());}

function setMode(m){
  CURMODE=m;
  document.getElementById("modeYear").classList.toggle("active",m==="year");
  document.getElementById("modeWeek").classList.toggle("active",m==="week");
  document.getElementById("modeMonth").classList.toggle("active",m==="month");
  document.getElementById("weekWrap").style.display=m==="week"?"inline-flex":"none";
  document.getElementById("monthWrap").style.display=m==="month"?"inline-flex":"none";
  document.getElementById("anioBlock").style.display=m==="year"?"block":"none";
  if(m==="year")renderPeriod("year",null);
  else if(m==="week")renderPeriod("week",SELWEEKS.slice());
  else renderPeriod("month",SELMONTHS.slice());
}

function handleFile(file){
  document.getElementById("err").style.display="none";
  const r=new FileReader();
  r.onload=ev=>{try{
    const wb=XLSX.read(ev.target.result,{type:"array",cellDates:true});
    const S=extractAll(wb);
    if(!S){showErr("No encontré las hojas esperadas (DATA SEGUNDAS, REPORTES, REPORTE DE TELAS).");return;}
    buildState(S,file.name,false);window.scrollTo({top:0,behavior:"smooth"});
  }catch(err){showErr("No pude leer el archivo: "+err.message);console.error(err);}};
  r.readAsArrayBuffer(file);
}
function monthOf(f){if(f instanceof Date)return f.getMonth();if(typeof f==="string"){const d=new Date(f);if(!isNaN(d))return d.getMonth();const m=f.match(/-(\d{2})-/);if(m)return +m[1]-1;}return null;}
function yearOf(f){if(f instanceof Date)return f.getFullYear();if(typeof f==="string"){const m=f.match(/(20\d{2})/);if(m)return +m[1];}return null;}
function num(v){if(v==null)return 0;if(typeof v==="number")return isFinite(v)?v:0;const n=parseFloat(String(v).replace(/[^0-9.\-]/g,""));return isFinite(n)?n:0;}

function extractAll(wb){
  let data=null,telas=null,repRows=null;
  for(const name of wb.SheetNames){
    const arr=XLSX.utils.sheet_to_json(wb.Sheets[name],{defval:null});
    if(arr.length){const cols=Object.keys(arr[0]||{});
      if(["CLIENTE","AREA GENERADORA","MOTIVO DE 2DA","CANTIDAD","SEMANA"].every(c=>cols.includes(c)))data=arr;
      else if(["COD TELA","SEMANA"].every(c=>cols.includes(c)))telas=arr;}
    // REPORTES: header desplazado -> leer como matriz
    if(!repRows){const m=XLSX.utils.sheet_to_json(wb.Sheets[name],{header:1,defval:null});
      let hi=-1;for(let i=0;i<m.length;i++){const row=(m[i]||[]).map(x=>String(x).trim().toUpperCase());if(row.includes("FECHA")&&row.includes("SEMANA")&&row.some(c=>c.includes("CONFECCION"))){hi=i;break;}}
      if(hi>=0){const H=(m[hi]||[]).map(x=>String(x).trim().toUpperCase());
        const ci=n=>H.findIndex(h=>h.includes(n));
        const iF=ci("FECHA"),iC=ci("CONFECCION"),iS=H.indexOf("CANTIDAD"),iP=ci("PRECIO"),iW=H.indexOf("SEMANA");
        const out=[];for(let i=hi+1;i<m.length;i++){const r=m[i]||[];if(r[iF]==null)continue;out.push({fecha:r[iF],conf:num(r[iC]),seg:num(r[iS]),precio:num(r[iP]),week:num(r[iW])});}
        if(out.length)repRows=out;}}
  }
  if(!data||!repRows)return null;
  return {data,telas:telas||[],repRows};
}

function buildState(S,fname,frozen){
  const dataAll=S.data.filter(r=>yearOf(r["FECHA"])).map(r=>({cli:r["CLIENTE"],est:String(r["ESTILO"]),grp:r["GRUPO"],area:r["AREA GENERADORA"],mot:r["MOTIVO DE 2DA"],cant:num(r["CANTIDAD"]),sem:num(r["SEMANA"]),mcal:monthOf(r["FECHA"]),year:yearOf(r["FECHA"])}));
  const rep=S.repRows.map(r=>({year:yearOf(r.fecha),week:r.week,mcal:monthOf(r.fecha),conf:r.conf,seg:r.seg,precio:r.precio}));
  const telas26=(S.telas||[]).filter(r=>yearOf(r["FECHA"])===2026).map(r=>({sem:num(r["SEMANA"]),mcal:monthOf(r["FECHA"]),cod:String(r["COD TELA"]||"").toUpperCase().trim(),nom:String(r["NOMBRE TELA"]||"").trim(),est:String(r["ESTILO"]||"").trim(),grp:String(r["GRUPO"]||"").trim(),color:String(r["COLOR"]||"").trim()}));
  const years=[...new Set(rep.map(r=>r.year).filter(Boolean))].sort((a,b)=>a-b);
  STATE={dataAll,rep,telas26,years,maxYear:Math.max(...years),fname};
  CURYEAR=STATE.maxYear;
  initDash(frozen,fname);
}
function initDash(frozen,fname){
  document.getElementById("drop").style.display="none";
  document.getElementById("bar").style.display="flex";
  document.getElementById("dash").style.display="block";
  var _fn=document.getElementById("fname");if(_fn)_fn.textContent=fname;
  const chBtn=document.getElementById("changeBtn"),exBtn=document.getElementById("exportBtn"),badge=document.getElementById("embedBadge");
  if(frozen){chBtn.style.display="none";exBtn.style.display="none";badge.style.display="inline-block";}else{chBtn.style.display="";exBtn.style.display="";badge.style.display="none";}
  applyKind();buildYearControl();selectYear(STATE.maxYear);
}

/* ----- helpers año-conscientes ----- */
function ydata(){return STATE.dataAll.filter(r=>r.year===CURYEAR);}
function yrep(){return STATE.rep.filter(r=>r.year===CURYEAR);}
function latest(){return CURYEAR===STATE.maxYear;}
function monthOfRow(r){return latest()?FIX[r.sem]:r.mcal;} // mismo criterio que dataPeriod/repMonth: evita que las fichas usen un "mes" distinto al de la tabla principal
function priorYear(){const ys=STATE.years.filter(y=>y<CURYEAR);return ys.length?Math.max(...ys):null;}
function repWeek(W){return yrep().find(r=>r.week===W)||{conf:0,seg:0,precio:0};}
function repMonth(m){const rs=latest()?yrep().filter(r=>FIX[r.week]===m):yrep().filter(r=>r.mcal===m);return {conf:rs.reduce((s,r)=>s+r.conf,0),seg:rs.reduce((s,r)=>s+r.seg,0),precio:rs.reduce((s,r)=>s+r.precio,0)};}
function repWeeks(arr){let conf=0,seg=0,precio=0;arr.forEach(w=>{const r=repWeek(w);conf+=r.conf;seg+=r.seg;precio+=(r.precio||0);});return {conf,seg,precio};}
function repMonths(arr){let conf=0,seg=0,precio=0;arr.forEach(m=>{const r=repMonth(m);conf+=r.conf;seg+=r.seg;precio+=(r.precio||0);});return {conf,seg,precio};}
function repMonthCal(m,year){const rs=STATE.rep.filter(r=>r.year===year&&r.mcal===m);return {conf:rs.reduce((s,r)=>s+r.conf,0),seg:rs.reduce((s,r)=>s+r.seg,0),precio:rs.reduce((s,r)=>s+r.precio,0)};}
function acumY(year){const rs=STATE.rep.filter(r=>r.year===year);return {conf:rs.reduce((s,r)=>s+r.conf,0),seg:rs.reduce((s,r)=>s+r.seg,0)};}
function pc(seg,conf){return conf?+(seg/conf*100).toFixed(2):0;}
function monthsOfYear(){const ms=latest()?yrep().map(r=>FIX[r.week]):yrep().map(r=>r.mcal);return [...new Set(ms.filter(m=>m!=null))].sort((a,b)=>a-b);}
function weeksOfYear(){return [...new Set(yrep().map(r=>r.week).filter(w=>w>0))].sort((a,b)=>a-b);}
function dataPeriod(mode,valueOrArr){if(mode==="year")return ydata();const vals=Array.isArray(valueOrArr)?valueOrArr:[valueOrArr];const set=new Set(vals);const d=ydata();return mode==="week"?d.filter(r=>set.has(r.sem)):(latest()?d.filter(r=>set.has(FIX[r.sem])):d.filter(r=>set.has(r.mcal)));}
function groupSum(rows,key){const m={};rows.forEach(r=>{const k=r[key];if(k==null||k==="")return;m[k]=(m[k]||0)+r.cant;});return Object.keys(m).map(k=>({k,v:m[k]})).sort((a,b)=>b.v-a.v);}

